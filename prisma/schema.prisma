// SangPlus CRM – Prisma schema
// PostgreSQL, MVP-focused

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  OWNER
  MANAGER
  TEACHER
}

enum StudentStatus {
  ACTIVE
  INACTIVE
}

enum GroupStatus {
  ACTIVE
  INACTIVE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         Role
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  teacher          Teacher?
  startedSessions  LessonSession[]
  createdPayments  Payment[]
}

model Teacher {
  id        String   @id @default(cuid())
  fullName  String
  phone     String?
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id])
  groupTeachers GroupTeacher[]
}

model Student {
  id        String        @id @default(cuid())
  fullName  String
  phone     String?
  status    StudentStatus @default(ACTIVE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  groupStudents GroupStudent[]
  attendances   Attendance[]
  payments      Payment[]
}

model Group {
  id              String      @id @default(cuid())
  name            String
  status          GroupStatus @default(ACTIVE)
  // Monthly fee in cents (e.g. 150000 = 150 000 UZS)
  monthlyFeeCents Int         @default(0)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  groupStudents GroupStudent[]
  groupTeachers GroupTeacher[]
  sessions      LessonSession[]
  payments      Payment[]
}

// Many-to-many: Student <-> Group
model GroupStudent {
  groupId   String
  studentId String
  // Track when student joined so overdue can be computed from this date
  joinedAt  DateTime @default(now())

  group   Group   @relation(fields: [groupId], references: [id])
  student Student @relation(fields: [studentId], references: [id])

  @@unique([groupId, studentId])
}

// Many-to-many: Teacher <-> Group
model GroupTeacher {
  groupId   String
  teacherId String

  group   Group   @relation(fields: [groupId], references: [id])
  teacher Teacher @relation(fields: [teacherId], references: [id])

  @@unique([groupId, teacherId])
}

// A single lesson "start" event for a group
model LessonSession {
  id            String   @id @default(cuid())
  groupId       String
  startedByUserId String
  startedAt     DateTime @default(now())

  group       Group        @relation(fields: [groupId], references: [id])
  startedBy   User         @relation(fields: [startedByUserId], references: [id])
  attendances Attendance[]
}

// Per-student attendance record inside a session
model Attendance {
  id        String           @id @default(cuid())
  sessionId String
  studentId String
  status    AttendanceStatus @default(ABSENT)
  markedAt  DateTime         @default(now())

  session LessonSession @relation(fields: [sessionId], references: [id])
  student Student       @relation(fields: [studentId], references: [id])

  @@unique([sessionId, studentId])
}

// Monthly payment record
// forMonth is always normalised to YYYY-MM-01 (first day of the month)
model Payment {
  id             String   @id @default(cuid())
  studentId      String
  groupId        String
  // Amount stored in cents (e.g. 150000 = 150 000 UZS)
  amountCents    Int
  // Always normalised to the 1st of the month: YYYY-MM-01T00:00:00Z
  forMonth       DateTime
  paidAt         DateTime @default(now())
  createdByUserId String
  note           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  student     Student @relation(fields: [studentId], references: [id])
  group       Group   @relation(fields: [groupId], references: [id])
  createdBy   User    @relation(fields: [createdByUserId], references: [id])

  // A student can only have one payment per group per month
  @@unique([studentId, groupId, forMonth])
}
